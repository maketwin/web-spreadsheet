{
  "name": "web-spreadsheet",
  "version": "1.0.0",
  "description": "A modern TypeScript spreadsheet SDK with 4-layer architecture",
  "type": "module",
  "main": "./dist/web-spreadsheet.umd.js",
  "module": "./dist/web-spreadsheet.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/web-spreadsheet.es.js",
      "require": "./dist/web-spreadsheet.umd.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "typecheck:js": "tsc --noEmit -p tsconfig.checkjs.json"
  },
  "keywords": [
    "spreadsheet",
    "excel",
    "canvas",
    "typescript",
    "sdk"
  ],
  "author": "sunxin <boss@sunxin.local>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maketwin/web-spreadsheet.git"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.27.0",
    "dexie": "^4.4.4",
    "xlsx": "^0.18.5"
  }
}
